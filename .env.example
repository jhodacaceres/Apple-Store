# ============================================================
# Apple Zone — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio (ya está en .gitignore).
# ============================================================

# Supabase — obtén estos valores en:
# Dashboard → Settings → API → Project URL / anon public key
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# El número de WhatsApp se configura desde el panel de administración
# en Ajustes → Contacto Público (se guarda en Supabase).
